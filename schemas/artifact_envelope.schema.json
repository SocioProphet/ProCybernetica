{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/procybernetica/artifact_envelope.schema.json",
  "title": "ProCybernetica ArtifactEnvelope",
  "description": "Public envelope for durable outputs, reports, models, prompts, traces, replays, policies, datasets, media, and evidence-bearing artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_id", "artifact_type", "created_at", "producer_node", "provenance_refs", "policy_refs"],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "artifact_id": { "$ref": "#/$defs/id" },
    "artifact_type": { "enum": ["plan", "report", "patch", "model", "prompt", "trace", "replay", "policy", "dataset", "simulation", "media", "claim_set", "evidence", "other"] },
    "media_type": { "type": "string" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "producer_node": { "$ref": "#/$defs/id" },
    "subject_refs": { "$ref": "#/$defs/string_array" },
    "hash_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
    "storage_uri": { "type": "string" },
    "labels": { "$ref": "#/$defs/string_array" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "retention_class": { "enum": ["ephemeral", "operational", "forensic", "regulated", "archival"] },
    "policy_refs": { "$ref": "#/$defs/string_array" },
    "provenance_refs": { "$ref": "#/$defs/string_array" },
    "public_release_state": { "enum": ["public", "public-sanitized", "public-synthetic", "withheld-specific"] },
    "notes": { "type": "string" }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._:/@#-]+$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "string_array": { "type": "array", "items": { "type": "string" }, "default": [] }
  }
}
