{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/procybernetica/command_envelope.schema.json",
  "title": "ProCybernetica CommandEnvelope",
  "description": "Typed authority-bearing command from one node to another.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "command_id", "issued_at", "issuer", "receiver", "verb", "policy_refs"],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "command_id": { "$ref": "#/$defs/id" },
    "issued_at": { "$ref": "#/$defs/timestamp" },
    "issuer": { "$ref": "#/$defs/id" },
    "receiver": { "$ref": "#/$defs/id" },
    "verb": { "type": "string", "minLength": 1 },
    "objective": { "type": "string" },
    "parameters": { "type": "object", "additionalProperties": true },
    "constraints": { "type": "object", "additionalProperties": true },
    "side_effect_class": { "enum": ["none", "local_write", "cross_repo_write", "external_api", "physical_actuation", "deployment", "other"] },
    "max_risk": { "type": "number", "minimum": 0, "maximum": 1 },
    "min_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "start_deadline": { "$ref": "#/$defs/timestamp" },
    "end_deadline": { "$ref": "#/$defs/timestamp" },
    "expected_artifacts": { "$ref": "#/$defs/string_array" },
    "policy_refs": { "$ref": "#/$defs/string_array" },
    "provenance_refs": { "$ref": "#/$defs/string_array" },
    "replay_required": { "type": "boolean", "default": true },
    "notes": { "type": "string" }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._:/@#-]+$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "string_array": { "type": "array", "items": { "type": "string" }, "default": [] }
  }
}
