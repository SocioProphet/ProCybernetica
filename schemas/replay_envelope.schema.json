{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/procybernetica/replay_envelope.schema.json",
  "title": "ProCybernetica ReplayEnvelope",
  "description": "Replay manifest for reconstructing a consequential episode under declared data, policy, version, and evidence bounds.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "replay_id",
    "subject_node",
    "episode_kind",
    "window_start",
    "window_end",
    "event_log_uri",
    "version_pins",
    "policy_refs",
    "artifact_refs"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "replay_id": { "$ref": "#/$defs/id" },
    "subject_node": { "$ref": "#/$defs/id" },
    "episode_kind": {
      "enum": ["lifecycle", "command", "delegation", "workflow", "pull_request", "deployment", "incident", "promotion", "evaluation", "other"]
    },
    "window_start": { "$ref": "#/$defs/timestamp" },
    "window_end": { "$ref": "#/$defs/timestamp" },
    "event_log_uri": { "type": "string", "minLength": 1 },
    "version_pins": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Named versions for schemas, policies, models, prompts, planners, code, data, and runtime surfaces used for replay interpretation."
    },
    "policy_refs": { "$ref": "#/$defs/string_array" },
    "artifact_refs": { "$ref": "#/$defs/string_array" },
    "trace_refs": { "$ref": "#/$defs/string_array" },
    "input_refs": { "$ref": "#/$defs/string_array" },
    "expected_output_refs": { "$ref": "#/$defs/string_array" },
    "redaction_policy_refs": { "$ref": "#/$defs/string_array" },
    "notes": { "type": "string" }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._:/@#-]+$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "string_array": { "type": "array", "items": { "type": "string" }, "default": [] }
  }
}
